{
  "name": "okoffice-workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:node": "npm --workspace @okoffice/okoffice-node run build",
    "dev:shell": "npm --workspace @okoffice/shell run dev",
    "build:shell": "npm --workspace @okoffice/shell run build",
    "dist:shell": "npm --workspace @okoffice/shell run dist",
    "doctor": "python scripts/doctor.py",
    "pack:node": "npm --workspace @okoffice/okoffice-node pack --dry-run",
    "setup": "python scripts/setup_dev.py",
    "smoke": "python scripts/smoke.py",
    "test": "pytest -q && npm --workspace @okoffice/okoffice-node test",
    "test:node": "npm --workspace @okoffice/okoffice-node test"
  }
}
