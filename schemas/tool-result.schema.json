{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentpdf.dev/schemas/tool-result.json",
  "title": "ToolResult",
  "type": "object",
  "required": [
    "job_id",
    "status",
    "tool"
  ],
  "properties": {
    "job_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "succeeded",
        "failed",
        "cancelled"
      ]
    },
    "tool": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "artifact.schema.json"
      }
    },
    "validation": {
      "$ref": "validation-report.schema.json"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "usage": {
      "type": "object"
    },
    "next_recommended_tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "data": {
      "type": "object"
    },
    "error": {
      "$ref": "error.schema.json"
    }
  },
  "additionalProperties": false
}
