{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentpdf.dev/schemas/tool-manifest.json",
  "title": "ToolManifest",
  "type": "object",
  "required": [
    "tools"
  ],
  "properties": {
    "manifest_version": {
      "type": "string"
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "status",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "stable",
              "beta",
              "experimental",
              "planned",
              "cloud_only"
            ]
          },
          "description": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "interfaces": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "input_schema": {
            "type": "object"
          },
          "output_schema": {
            "type": "object"
          },
          "implemented": {
            "type": "boolean"
          }
        }
      }
    }
  },
  "additionalProperties": false
}
