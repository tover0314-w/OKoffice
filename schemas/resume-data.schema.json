{
  "$defs": {
    "BulletEntry": {
      "description": "Bullet-list only entry \u2014 skill groups, interest lists.\n\nAuto-detected when: has only 'highlights' list with no other characteristic fields.",
      "properties": {
        "entry_id": {
          "description": "Unique identifier for this entry",
          "title": "Entry Id",
          "type": "string"
        },
        "entry_type": {
          "const": "bullet",
          "default": "bullet",
          "title": "Entry Type",
          "type": "string"
        },
        "highlights": {
          "description": "Required bullet items (e.g. ['Python', 'TypeScript', 'Go'])",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Highlights",
          "type": "array"
        }
      },
      "required": [
        "highlights"
      ],
      "title": "BulletEntry",
      "type": "object"
    },
    "ContactInfo": {
      "description": "Contact information displayed at the top of a resume.",
      "properties": {
        "email": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Primary email address (e.g. 'alex@example.com')",
          "title": "Email"
        },
        "phone": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Phone number in display format (e.g. '+1 (555) 123-4567')",
          "title": "Phone"
        },
        "location": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "City, State/Country for display (e.g. 'San Francisco, CA')",
          "title": "Location"
        },
        "linkedin": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "LinkedIn profile URL",
          "title": "Linkedin"
        },
        "website": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Personal website or portfolio URL",
          "title": "Website"
        },
        "github": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "GitHub profile URL",
          "title": "Github"
        }
      },
      "title": "ContactInfo",
      "type": "object"
    },
    "EducationEntry": {
      "description": "Education entry (degree, certification, coursework).\n\nAuto-detected when: has 'gpa' or 'honors' field, or title contains degree keywords.",
      "properties": {
        "entry_id": {
          "description": "Unique identifier for this entry (e.g. 'exp_1', 'edu_3')",
          "title": "Entry Id",
          "type": "string"
        },
        "title": {
          "description": "Degree or program name (e.g. 'B.S. Computer Science')",
          "title": "Title",
          "type": "string"
        },
        "organization": {
          "description": "Institution name (e.g. 'Stanford University')",
          "title": "Organization",
          "type": "string"
        },
        "location": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "City, State/Country (e.g. 'New York, NY')",
          "title": "Location"
        },
        "date_range": {
          "anyOf": [
            {
              "$ref": "#/$defs/ResumeDateRange"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Start/end dates in Month YYYY format"
        },
        "url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Relevant URL (project link, publication DOI, etc.)",
          "title": "Url"
        },
        "highlights": {
          "description": "Bullet points or description lines for this entry",
          "items": {
            "type": "string"
          },
          "title": "Highlights",
          "type": "array"
        },
        "entry_type": {
          "const": "education",
          "default": "education",
          "title": "Entry Type",
          "type": "string"
        },
        "gpa": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "GPA if notable (e.g. '3.9/4.0')",
          "title": "Gpa"
        },
        "honors": {
          "description": "Honors, awards, or relevant coursework",
          "items": {
            "type": "string"
          },
          "title": "Honors",
          "type": "array"
        }
      },
      "required": [
        "title",
        "organization"
      ],
      "title": "EducationEntry",
      "type": "object"
    },
