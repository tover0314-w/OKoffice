  "description": "Complete structured resume data model.\n\nThis is the single source of truth for resume content.\nThe rendering pipeline reads this model and applies design tokens\nand layout rules to produce the final PDF.",
  "properties": {
    "name": {
      "description": "Full name of the candidate (e.g. 'Alexandra Chen')",
      "title": "Name",
      "type": "string"
    },
    "headline": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Professional headline or tagline (e.g. 'Senior Backend Engineer')",
      "title": "Headline"
    },
    "photo_url": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional photo URL or local file path",
      "title": "Photo Url"
    },
    "contact": {
      "$ref": "#/$defs/ContactInfo",
      "description": "Contact information displayed at the top of the resume"
    },
    "sections": {
      "description": "Ordered resume sections, each containing typed entries",
      "items": {
        "$ref": "#/$defs/ResumeSection"
      },
      "title": "Sections",
      "type": "array"
    },
    "metadata": {
      "additionalProperties": true,
      "description": "Optional metadata (locale, custom fields, template hints)",
      "title": "Metadata",
      "type": "object"
    }
  },
  "required": [
    "name"
  ],
  "title": "ResumeData",
  "type": "object"
}