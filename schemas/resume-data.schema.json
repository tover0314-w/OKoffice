    "ResumeDateRange": {
      "description": "Date range with ATS-compliant formatting.",
      "properties": {
        "start": {
          "description": "Start date in 'Month YYYY' format (e.g. 'January 2022', 'Sep 2020'). ATS parsers read this reliably.",
          "title": "Start",
          "type": "string"
        },
        "end": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "End date in 'Month YYYY' format, or 'Present' for current positions. Leave empty for single-date entries.",
          "title": "End"
        }
      },
      "required": [
        "start"
      ],
      "title": "ResumeDateRange",
      "type": "object"
    },
    "ResumeSection": {
      "description": "A resume section containing entries of a specific type.",
      "properties": {
        "section_id": {
          "description": "Unique section identifier (e.g. 'experience', 'education')",
          "title": "Section Id",
          "type": "string"
        },
        "title": {
          "description": "Section header displayed to the reader. For ATS compatibility, use standard names: 'Work Experience', 'Education', 'Skills', 'Certifications', 'Projects', 'Publications', 'Languages', 'Volunteer Experience', 'Awards', 'Summary', 'Professional Summary'.",
          "title": "Title",
          "type": "string"
        },
        "entry_type": {
          "description": "Expected entry type for entries in this section",
          "title": "Entry Type",
          "type": "string"
        },
        "entries": {
          "description": "Ordered list of entries in this section",
          "items": {
            "discriminator": {
              "mapping": {
                "bullet": "#/$defs/BulletEntry",
                "education": "#/$defs/EducationEntry",
                "experience": "#/$defs/ExperienceEntry",
                "normal": "#/$defs/NormalEntry",
                "numbered": "#/$defs/NumberedEntry",
                "one_line": "#/$defs/OneLineEntry",
                "publication": "#/$defs/PublicationEntry",
                "reversed_numbered": "#/$defs/ReversedNumberedEntry",
                "text": "#/$defs/TextEntry"
              },
              "propertyName": "entry_type"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/ExperienceEntry"
              },
              {
                "$ref": "#/$defs/EducationEntry"
              },
              {
                "$ref": "#/$defs/PublicationEntry"
              },
              {
                "$ref": "#/$defs/NormalEntry"
              },
              {
                "$ref": "#/$defs/OneLineEntry"
              },
              {
                "$ref": "#/$defs/BulletEntry"
              },
              {
                "$ref": "#/$defs/TextEntry"
              },
              {
                "$ref": "#/$defs/NumberedEntry"
              },
              {
                "$ref": "#/$defs/ReversedNumberedEntry"
              }
            ]
          },
          "title": "Entries",
          "type": "array"
        },
        "order": {
          "default": 0,
          "description": "Display order \u2014 0 appears first",
          "title": "Order",
          "type": "integer"
        }
      },
      "required": [
        "section_id",
        "title",
        "entry_type"
      ],
      "title": "ResumeSection",
      "type": "object"
    },
