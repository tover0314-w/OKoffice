{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentpdf.dev/schemas/common.json",
  "title": "AgentPDF Common Types",
  "type": "object",
  "$defs": {
    "FileRef": {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "local_path",
            "artifact_id",
            "url",
            "bytes",
            "connector_file"
          ]
        },
        "path": {
          "type": "string"
        },
        "artifact_id": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "password": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "PageRange": {
      "type": "string",
      "description": "1-indexed page range syntax such as all, 1, 1-3, 1-3,7, odd, even"
    },
    "BBox": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "minItems": 4,
      "maxItems": 4
    }
  }
}
