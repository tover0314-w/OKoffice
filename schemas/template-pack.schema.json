{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://okpdf.local/schemas/template-pack.schema.json",
  "title": "OKoffice Template Pack",
  "type": "object",
  "required": ["pack_id", "name", "version", "templates"],
  "properties": {
    "pack_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "cloud_required": {
      "type": "boolean",
      "default": false
    },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["template_id", "name", "base_template", "fields", "sample_data"],
        "properties": {
          "template_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "base_template": {
            "type": "string"
          },
          "target_profile": {
            "type": "string"
          },
          "default_style_pack": {
            "type": "string"
          },
          "fields": {
            "type": "object",
            "properties": {
              "required": {
                "type": "array",
                "items": {"type": "string"}
              },
              "optional": {
                "type": "array",
                "items": {"type": "string"}
              }
            },
            "additionalProperties": true
          },
          "layout_slots": {
            "type": "array",
            "items": {"type": "string"}
          },
          "supported_block_types": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "section",
                "code",
                "table",
                "image",
                "slide",
                "audio_reference",
                "video_reference",
                "media_reference",
                "citation"
              ]
            },
            "description": "Agent-supplied block types this template accepts in data.blocks."
          },
          "color_schemes": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "primary": {"type": "string"},
                "accent": {"type": "string"},
                "text": {"type": "string"}
              },
              "additionalProperties": false
            }
          },
          "sample_data": {
            "type": "object"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
