{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://okpdf.dev/schemas/artifact-bundle-manifest.schema.json",
  "title": "OKoffice Artifact Bundle Manifest",
  "type": "object",
  "required": ["bundle_version", "bundle_id", "title", "created_at", "artifact_count", "artifacts", "safety"],
  "additionalProperties": true,
  "properties": {
    "bundle_version": {
      "type": "string"
    },
    "bundle_id": {
      "type": "string",
      "pattern": "^bundle_[a-zA-Z0-9]+$"
    },
    "title": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "artifact_count": {
      "type": "integer",
      "minimum": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["artifact_id", "source_path", "bundle_path", "mime_type", "size_bytes", "sha256"],
        "additionalProperties": true,
        "properties": {
          "artifact_id": {
            "type": "string",
            "pattern": "^art_[a-zA-Z0-9]+$"
          },
          "source_path": {
            "type": "string"
          },
          "bundle_path": {
            "type": "string",
            "pattern": "^artifacts/[^/]+$"
          },
          "mime_type": {
            "type": "string"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "page_count": {
            "type": ["integer", "null"],
            "minimum": 0
          },
          "source_tool": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "safety": {
      "type": "object",
      "required": ["contains_input_hashes", "mutates_inputs", "zip_paths_are_sanitized"],
      "properties": {
        "contains_input_hashes": {
          "const": true
        },
        "mutates_inputs": {
          "const": false
        },
        "zip_paths_are_sanitized": {
          "const": true
        }
      }
    }
  }
}
