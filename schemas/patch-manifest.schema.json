{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://okpdf.dev/schemas/patch-manifest.schema.json",
  "title": "AgentPDF Patch Manifest",
  "type": "object",
  "required": [
    "patch_manifest_version",
    "patch_id",
    "input_path",
    "input_artifact",
    "operation_count",
    "operations",
    "safety",
    "validation_required"
  ],
  "additionalProperties": true,
  "properties": {
    "patch_manifest_version": {
      "type": "string"
    },
    "patch_id": {
      "type": "string",
      "pattern": "^patch_[a-zA-Z0-9]+$"
    },
    "input_path": {
      "type": "string"
    },
    "input_artifact": {
      "type": "object",
      "additionalProperties": true
    },
    "composition_path": {
      "type": ["string", "null"]
    },
    "layer_manifest_path": {
      "type": ["string", "null"]
    },
    "reason": {
      "type": "string"
    },
    "operation_count": {
      "type": "integer",
      "minimum": 1
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["operation_id", "op", "title", "source_refs"],
        "additionalProperties": true,
        "properties": {
          "operation_id": {
            "type": "string"
          },
          "op": {
            "type": "string",
            "enum": [
              "append_markdown",
              "append_code_block",
              "append_table",
              "append_image",
              "append_slide"
            ]
          },
          "title": {
            "type": "string"
          },
          "markdown": {
            "type": "string",
            "minLength": 1
          },
          "language": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "columns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rows": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "path": {
            "type": "string"
          },
          "caption": {
            "type": "string"
          },
          "body": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "subtitle": {
            "type": "string"
          },
          "image_path": {
            "type": "string"
          },
          "table": {
            "type": "object",
            "additionalProperties": true
          },
          "source_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "target_layer_refs": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "layer_ids": {
                "type": "array",
                "items": {"type": "string"}
              },
              "block_ids": {
                "type": "array",
                "items": {"type": "string"}
              },
              "target_slots": {
                "type": "array",
                "items": {"type": "string"}
              }
            }
          },
          "layer_evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "layer_id": {"type": "string"},
                "block_id": {"type": "string"},
                "block_type": {"type": "string"},
                "target_slot": {"type": "string"},
                "source_refs": {
                  "type": "array",
                  "items": {"type": "string"}
                },
                "anchor": {"type": "object"},
                "edit_policy": {"type": "object"}
              }
            }
          },
          "source_map_evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "block_id": {
                  "type": "string"
                },
                "source_ref": {
                  "type": "string"
                },
                "source_kind": {
                  "type": "string"
                },
                "pack_id": {
                  "type": "string"
                },
                "template_id": {
                  "type": "string"
                },
                "target_profile_id": {
                  "type": "string"
                },
                "target_slot": {
                  "type": ["string", "null"]
                }
              }
            }
          }
        }
      }
    },
    "source_ref_validation": {
      "type": "object",
      "required": ["status", "known_source_ref_count", "requested_source_refs", "missing_source_refs", "operation_count"],
      "additionalProperties": true,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["passed", "skipped"]
        },
        "composition_path": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "known_source_ref_count": {
          "type": "integer",
          "minimum": 0
        },
        "known_source_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requested_source_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_source_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "operation_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "operation_source_map": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["operation_id", "op", "source_refs", "matched_source_count", "matched_sources"],
        "additionalProperties": true,
        "properties": {
          "operation_id": {
            "type": "string"
          },
          "op": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "source_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "matched_source_count": {
            "type": "integer",
            "minimum": 0
          },
          "matched_sources": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      }
    },
    "layer_ref_validation": {
      "type": "object",
      "required": [
        "status",
        "known_layer_count",
        "requested_layer_ids",
        "requested_block_ids",
        "requested_target_slots",
        "missing_layer_refs",
        "operation_count"
      ],
      "additionalProperties": true,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["passed", "skipped"]
        },
        "layer_manifest_path": {"type": "string"},
        "template_layer_manifest_id": {"type": "string"},
        "reason": {"type": "string"},
        "known_layer_count": {
          "type": "integer",
          "minimum": 0
        },
        "known_layer_ids": {
          "type": "array",
          "items": {"type": "string"}
        },
        "requested_layer_ids": {
          "type": "array",
          "items": {"type": "string"}
        },
        "requested_block_ids": {
          "type": "array",
          "items": {"type": "string"}
        },
        "requested_target_slots": {
          "type": "array",
          "items": {"type": "string"}
        },
        "missing_layer_refs": {
          "type": "array",
          "items": {"type": "string"}
        },
        "operation_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "operation_layer_map": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "operation_id",
          "op",
          "layer_ids",
          "block_ids",
          "target_slots",
          "matched_layer_count",
          "matched_layers"
        ],
        "additionalProperties": true,
        "properties": {
          "operation_id": {"type": "string"},
          "op": {"type": "string"},
          "title": {"type": "string"},
          "layer_ids": {
            "type": "array",
            "items": {"type": "string"}
          },
          "block_ids": {
            "type": "array",
            "items": {"type": "string"}
          },
          "target_slots": {
            "type": "array",
            "items": {"type": "string"}
          },
          "matched_layer_count": {
            "type": "integer",
            "minimum": 0
          },
          "matched_layers": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      }
    },
    "safety": {
      "type": "object",
      "required": ["mutates_input", "requires_new_output_path", "supported_operations"],
      "additionalProperties": true,
      "properties": {
        "mutates_input": {
          "const": false
        },
        "requires_new_output_path": {
          "const": true
        },
        "supported_operations": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "append_markdown",
              "append_code_block",
              "append_table",
              "append_image",
              "append_slide"
            ]
          }
        },
        "supports_layer_anchors": {
          "type": "boolean"
        },
        "claims_layout_preservation": {
          "const": false
        }
      }
    },
    "validation_required": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
