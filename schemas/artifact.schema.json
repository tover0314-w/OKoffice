{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentpdf.dev/schemas/artifact.json",
  "title": "Artifact",
  "type": "object",
  "required": [
    "artifact_id",
    "kind",
    "mime_type",
    "created_at"
  ],
  "properties": {
    "artifact_id": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "pdf",
        "image",
        "json",
        "markdown",
        "html",
        "text",
        "zip",
        "index",
        "other"
      ]
    },
    "path": {
      "type": "string"
    },
    "url": {
      "type": "string"
    },
    "mime_type": {
      "type": "string"
    },
    "filename": {
      "type": "string"
    },
    "size_bytes": {
      "type": "integer"
    },
    "sha256": {
      "type": "string"
    },
    "page_count": {
      "type": "integer"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
