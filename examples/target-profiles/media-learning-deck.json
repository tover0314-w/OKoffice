  },
  "accepted_block_types": [
    "slide",
    "section",
    "image",
    "table",
    "code",
    "audio_reference",
    "video_reference",
    "media_reference",
    "citation"
  ],
  "accepted_context_types": ["text", "document", "image", "data", "code", "audio", "video", "web_link"],
  "validation_required": ["render_check", "evidence_coverage_report"]
}
